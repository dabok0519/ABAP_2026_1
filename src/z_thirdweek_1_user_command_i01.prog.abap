MODULE user_command_0100 INPUT.

" EXIT 모듈 생성 및 설정
  CASE ok_code.
    when 'BACK'.
      LEAVE TO SCREEN 0.
     WHEN 'EXIT' OR 'CANC'.
      LEAVE PROGRAM.
  ENDCASE.

ENDMODULE.
